# A股自选股智能分析系统 - 环境配置
# 复制此文件为 .env 并填入实际配置

# ==========================================
# 飞书机器人 Webhook（必填一个）
# ==========================================

# 方式一：飞书自定义机器人 Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/ae0d1655-eba9-409a-b5c3-1570ba2c4904

# ==========================================
# 通知配置
# ==========================================

# 启用管理层摘要模式（输出：能不能做/为什么/风险在哪/接下来盯什么）
REPORT_SUMMARY_ONLY=true

# Web 报告详情页 URL（配置后飞书推送会带"查看详情"链接）
# WEB_REPORT_BASE_URL=https://你的域名或IP:端口

# ==========================================
# AI 模型配置（必填）
# ==========================================

# 示例：火山引擎方舟
# LITELLM_MODEL=claude-sonnet-4-20250514
# LITELLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LITELLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 示例：OpenAI
# LITELLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ==========================================
# 其他配置（可选）
# ==========================================

# 股票池配置（逗号分隔的股票代码）
# STOCK_POOL=600519,000001,300750

# 推送场景标签（可选：morning=早报, evening=晚报, manual=手动）
# REPORT_SCENE_LABEL=morning